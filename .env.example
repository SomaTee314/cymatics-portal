# Copy to `.env.local` for local dev (never commit `.env.local`).
# Next loads `.env`, `.env.local`, etc. — if BOTH exist, `.env.local` wins per variable.
# Do not leave empty `NEXT_PUBLIC_*=` lines in `.env.local` or they override values from `.env`.
# Chunk 404 / stale HMR: `npm run dev:3005:fresh` (Windows: kills listener on 3005, cleans .next, starts dev).
#
# Vercel: Project → Settings → Environment Variables (Production + Preview).
# `NEXT_PUBLIC_*` are inlined at **build** time — redeploy after changing them.
# Optional: VERCEL_TOKEN (https://vercel.com/account/tokens) for `npm run vercel:push:env` (all app env) or
# `npm run vercel:env:supabase` (Supabase keys only) — API sync; avoids a Windows `vercel env add` hang.

# Optional: canonical URL for metadata/OG (defaults to https://www.cymaticsportal.com in Vercel production)
# NEXT_PUBLIC_SITE_URL=https://www.cymaticsportal.com

# --- Supabase (required for auth + profiles) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: webhooks + admin updates (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
# Supabase CLI auth: npm run db:supabase:reauth (or: npm run db:supabase:login)
# SUPABASE_ACCESS_TOKEN=sbp_...   # https://supabase.com/dashboard/account/tokens
#
# Option B (CLI): npm run db:remote — login + link + db push
#
# --- Postgres (for `npm run migrate` / `npm run test:db` only) ---
# Never use NEXT_PUBLIC_* for DB URLs. Uncomment exactly one approach:
#
# A) URI from Dashboard → Connect → Direct → Connection string → Type "URI"
#    (choose Direct / Session / Transaction per network; copy full string, one line)
# SUPABASE_DB_URL=postgresql://...
#
# B) Database user password (not anon / not service_role — Project Settings → Database)
#    plus public project URL. Script builds transaction pooler host on port 6543.
# SUPABASE_DB_PASSWORD=
# SUPABASE_POOLER_REGION=us-east-1
#    If connection fails, set region to match "aws-0-REGION.pooler..." in Connect (e.g. eu-west-1).
#
# Validate: npm run verify:supabase (HTTP) then npm run test:db (Postgres wire).

# Supabase → Authentication → URL Configuration (Dashboard; required for magic links):
# Site URL (production): https://www.cymaticsportal.com
# Redirect URLs (one per line; wildcards allow ?next= after /auth/callback):
#   https://www.cymaticsportal.com/auth/callback**
#   https://cymaticsportal.com/auth/callback**
#   https://cymatics-portal.vercel.app/auth/callback**
#   https://*.vercel.app/auth/callback**
#   http://localhost:3000/auth/callback**
#   http://localhost:3005/auth/callback**

# =============================================================================
# Polar (checkout + webhooks)
# Paste your real values into `.env.local` (same variable names).
# Dashboard: https://polar.sh → Settings → Organization / Developers / Products
#
# Webhook URL: https://<your-domain>/api/webhooks/polar
# Subscribe to: subscription.created, subscription.updated, subscription.canceled, order.paid
# (Lifetime / one-time uses order.paid; subscriptions use subscription.*)
# =============================================================================

# Server-only: Personal Access Token (or org token) — used by `app/api/checkout/route.ts`
POLAR_ACCESS_TOKEN=

# Optional: `sandbox` or `production` (default production). Must match where your token/products live.
# POLAR_SERVER=sandbox

# Webhook signing secret when Polar calls `app/api/webhooks/polar` (required in production; verified via @polar-sh/sdk)
POLAR_WEBHOOK_SECRET=

# Your Polar organization UUID (Settings → Organization; optional if SDK infers org from token)
POLAR_ORGANIZATION_ID=

# Product IDs (UUIDs from each product in Polar — exposed to the browser for pricing page checkout)
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=
NEXT_PUBLIC_POLAR_PRO_YEARLY_PRODUCT_ID=
NEXT_PUBLIC_POLAR_CREATOR_PRODUCT_ID=
NEXT_PUBLIC_POLAR_CREATOR_YEARLY_PRODUCT_ID=
NEXT_PUBLIC_POLAR_LIFETIME_PRODUCT_ID=

# --- Dev bypass (Next.js shell + iframe postMessage payload) ---
# `next dev` unlocks all features by default (so the iframe does not stay on free-tier / Healing Presets).
#
# NEXT_PUBLIC_DEV_MODE:
#   true  — always unlock (do not use on production deploys)
#   false — use real tier from Supabase profile (still "next dev")
#   unset — same as unlock while NODE_ENV=development
#
# When testing free-tier UI in dev without unsetting NODE_ENV, also set:
#   NEXT_PUBLIC_FORCE_SUBSCRIPTION_GATES=true
#
# After changes, restart `next dev` (NEXT_PUBLIC_* is read at startup).
#
# Testing real Supabase magic-link auth on localhost:
#   1) Set NEXT_PUBLIC_DEV_MODE=false (and optionally FORCE_SUBSCRIPTION_GATES=true) and restart dev.
#   2) Supabase → Authentication → URL config: add http://localhost:3005 and
#      redirect http://localhost:3005/auth/callback (use your dev port if different).
#   3) Open /signup or /login. With dev unlock, shell still mocks the session, but
#      “Log in” / “Sign up” in the top bar open the real flows to verify email + callback.
NEXT_PUBLIC_DEV_MODE=true
# NEXT_PUBLIC_FORCE_SUBSCRIPTION_GATES=true
# If true: shell skips /pricing on iframe upgrade/session-expiry (Polar can stay off). Does not unlock the iframe; anonymous users still get free tier + sign-up gate.
# NEXT_PUBLIC_SUBSCRIPTION_PAUSED=true
