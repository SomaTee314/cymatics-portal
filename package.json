{
  "name": "cymatics-portal",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "predev": "python _build_portal.py && node scripts/generate-favicon.mjs && node scripts/sync-cymatics-public.mjs",
    "dev": "next dev",
    "dev:turbo": "python _build_portal.py && node scripts/sync-cymatics-public.mjs && next dev --turbo",
    "dev:3005": "python _build_portal.py && node scripts/sync-cymatics-public.mjs && next dev -p 3005",
    "dev:3005:clean": "node scripts/clean-next.mjs && python _build_portal.py && node scripts/sync-cymatics-public.mjs && next dev -p 3005",
    "dev:3005:fresh": "node scripts/kill-port.mjs 3005 && node scripts/clean-next.mjs && python _build_portal.py && node scripts/sync-cymatics-public.mjs && next dev -p 3005",
    "dev:clean": "node scripts/clean-next.mjs && python _build_portal.py && node scripts/sync-cymatics-public.mjs && next dev",
    "prebuild": "node scripts/prebuild.mjs",
    "build": "next build",
    "start": "next start",
    "generate:og": "node scripts/generate-og.mjs",
    "generate:favicon": "node scripts/generate-favicon.mjs",
    "migrate": "node scripts/run-migrations.mjs",
    "db:push": "npx supabase db push --include-all --yes",
    "db:supabase:login": "npx supabase login",
    "db:supabase:reauth": "node scripts/supabase-reauth.mjs",
    "db:supabase:link": "npx supabase link",
    "db:remote": "node scripts/supabase-option-b.mjs",
    "test:supabase": "node scripts/test-supabase.mjs",
    "test:db": "node scripts/test-postgres-connection.mjs",
    "verify:supabase": "node scripts/verify-supabase-schema.mjs",
    "verify:particle-landing": "node scripts/verify-particle-landing.mjs",
    "verify:annulus-julia": "node scripts/verify-annulus-julia.mjs",
    "vercel:env:supabase": "node scripts/sync-vercel-supabase-env.mjs",
    "vercel:push:env": "node scripts/vercel-push-env-from-local.mjs",
    "test:polar": "node scripts/test-polar-checkout.mjs",
    "github:push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/complete-github-push.ps1",
    "release:live": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/publish-to-live.ps1"
  },
  "dependencies": {
    "@polar-sh/sdk": "^0.46.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "date-fns": "^4.1.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "puppeteer": "^24.2.0",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.16",
    "sharp": "^0.33.5",
    "to-ico": "^1.1.2",
    "typescript": "^5.7.0"
  }
}
